// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "features": {
    "copilot": false
  },
  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 15,
  "ensure_final_newline_on_save": false,
  "format_on_save": "on",
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true
  },
  "language_overrides": {
    "C": {
      "format_on_save": "off"
    },
    "Rust": {
      "tab_size": 4
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "useParameterNames": true,
            "enable": "skip_trivial"
          },
          "closureReturnTypeHints": {
            "enable": "always"
          }
        }
      }
    },
    "gopls": {
      "initialization_options": {
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true
        }
      }
    },
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": true,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true,
          "includeInlayEnumMemberDeclarationTypes": true
        }
      }
    }
  },
  "relative_line_numbers": true,
  "remove_trailing_whitespace_on_save": true,
  "soft_wrap": "none",
  "tab_bar": {
    "show_nav_history_buttons": false
  },
  "theme": {
    "light": "Andromeda",
    "dark": "Andromeda"
  },
  "ui_font_family": "JetBrains Mono",
  "ui_font_size": 15,
  "vertical_scroll_margin": 5,
  "vim": {
    "use_multiline_find": true,
    "use_smartcase_find": true,
    "use_system_clipboard": "never"
  },
  "vim_mode": true,
  "tab_size": 2,
  "terminal": {
    "option_as_meta": true
  },
  "experimental.theme_overrides": {
    "terminal.ansi.black": "#1b1b23",
    "terminal.ansi.bright_black": "#3b3b4d",
    "terminal.ansi.red": "#ebb9b9",
    "terminal.ansi.bright_red": "#d95e59",
    "terminal.ansi.green": "#caf6bb",
    "terminal.ansi.bright_green": "#8fc587",
    "terminal.ansi.yellow": "#e6dfb8",
    "terminal.ansi.bright_yellow": "#ffcf85",
    "terminal.ansi.blue": "#cddbf9",
    "terminal.ansi.bright_blue": "#4a83c3",
    "terminal.ansi.magenta": "#f6bbe7",
    "terminal.ansi.bright_magenta": "#bf83b5",
    "terminal.ansi.cyan": "#b8dceb",
    "terminal.ansi.bright_cyan": "#4eb3cd",
    "terminal.ansi.white": "#c8cedc",
    "terminal.ansi.bright_white": "#abb2c2"
  }
}
